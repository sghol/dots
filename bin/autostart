#!/bin/sh

# Import graphical environment into systemd user manager
systemctl --user import-environment DISPLAY XAUTHORITY

# incerese speed of repeated key.
xset r rate 200 35 &

# Disable beep sound
xset -b &

# do not turn off Monitor
xset s off &
xset -dpms &

# Persian Keyboard Layout
# setxkbmap -layout us,ir -option grp:alt_shift_toggle &

# Disable touch pad
xinput disable "AlpsPS/2 ALPS GlidePoint" &

# set wallpaper
setbg &

# Notification program
dunst &

# Network systray
nm-applet &

# bluthooth
blueman-applet &

# Hide mouse pointer when not used 
unclutter &

xmodmap -e 'keycode 135 = Control_R' &
xmodmap -e 'add Control = Control_R' &

# composite 
picom -b
