#!/bin/sh


# colors
bg="#000000"
fg="#cccccc"
sel="#ffffff"

selected=$(find ~/dev ~/dev/lms -maxdepth 1 -mindepth 1 -type d | dmenu -i -p "Projects" -nb $bg -nf $fg -sb $sel -sf $bg ) || exit 0

# If nothing selected, exit
[ -z "$selected" ] && exit 0

# change directory to selected project path
cd "$selected" || exit 1

"$TERMINAL" -e "$EDITOR" .
